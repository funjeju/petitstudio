# ===========================================================================
# petit studio 환경변수 예시 — 02_ARCHITECTURE.md §3 참조
# 이 파일을 복사해 .env.local 로 만들고 값을 채우세요. .env.local 은 커밋 금지.
# ===========================================================================

# --- 서버 전용 (❌ 절대 클라이언트 노출 금지, NEXT_PUBLIC 접두어 금지) ---
OPENAI_API_KEY=

# Firebase Admin SDK (서버 함수에서 크레딧 차감/토큰 검증에 사용)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# 개행 포함 private key 는 \n 으로 이스케이프하거나 base64 로 넣고 서버에서 디코드
FIREBASE_ADMIN_PRIVATE_KEY=

# 월 총액 kill switch 임계값(USD)
MONTHLY_COST_CAP_USD=500

# 어드민 자기승격 허용 이메일(최초 어드민 부트스트랩용). 비우면 승격 불가.
ADMIN_EMAIL=

# --- 공개 가능 (클라이언트 SDK 설정용, Firestore 보안규칙으로 방어) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
