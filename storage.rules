rules_version = '2';

// petit studio Storage 규칙 — 03_DATA_MODEL.md §3
// 원본 업로드는 소유자만, 생성 결과물은 소유자 read + 서버 write.
service firebase.storage {
  match /b/{bucket}/o {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // 원본 업로드(가공 전): 소유자 read/write, 10MB 이하 이미지만.
    match /uploads/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 코어/생성 결과: 소유자 read. write는 서버(Admin SDK)만.
    match /coreImages/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if false;
    }
    match /generations/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if false;
    }
    match /trash/{uid}/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
